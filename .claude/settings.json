{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "NotebookEdit(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__microsoft-365__*",
      "mcp__1a28d9f5-8536-4b08-824a-f1226379edf0__*",
      "mcp__980c678b-631c-4930-9836-163192146737__*",
      "mcp__cbeac91d-1db6-4f9d-b70f-3160dc44ceec__*",
      "mcp__c1fc4002-5f49-5f9d-a4e5-93c4ef5d6a75__*",
      "mcp__Claude_in_Chrome__*",
      "mcp__Claude_Preview__*",
      "mcp__mcp-registry__*",
      "mcp__scheduled-tasks__*",
      "mcp__c5e16058-9852-4f16-bf31-99b3f0be0c4c__*",
      "mcp__figma__*",
      "mcp__Control_your_Mac__*",
      "mcp__computer-use__*",
      "mcp__ccd_session__*",
      "Read(//Volumes/daten/**)",
      "Edit(//Volumes/daten/jans-ai-hub/**)",
      "Write(//Volumes/daten/jans-ai-hub/**)",
      "Read(//Applications/**)",
      "Read(//Users/raphaeljans/Library/CloudStorage/**)",
      "Write(//Users/raphaeljans/Library/CloudStorage/OneDrive-FreigegebeneBibliotheken–JANS/**)"
    ],
    "deny": [],
    "additionalDirectories": [
      "/Volumes/daten/jans-ai-hub"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ ! -d /Volumes/daten/jans-ai-hub/skills ]; then echo 'WARNUNG NAS-WAECHTER: /Volumes/daten ist nicht gemountet — Skills, Agenten, Commands und Rules fehlen in dieser Session! Beheben: im Buero \"open smb://192.168.1.10/daten\", extern \"open smb://diskstation918.tail8265aa.ts.net/daten\" (Tailscale), danach Session neu starten. Diese Warnung dem Benutzer sofort anzeigen.'; fi",
            "timeout": 5,
            "statusMessage": "Prüfe NAS-Mount..."
          },
          {
            "type": "command",
            "command": "bash /Volumes/daten/jans-ai-hub/scripts/sync-task-check.sh --notify 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Prüfe Sync-Tasks..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Volumes/daten/jans-ai-hub/scripts/verbesserung-capture.sh 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__Control_your_Mac__osascript",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Volumes/daten/jans-ai-hub/scripts/mail-draft-guard.sh 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Volumes/daten/jans-ai-hub/scripts/umlaut-guard.sh 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
