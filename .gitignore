secrets/
**/.geocache.json

# Node
node_modules/
package-lock.json

# macOS
.DS_Store

# Transiente Laufzeit-Daten (NICHT versionieren)
output/
sync-tasks/
dispatch/
*.log

# Schwere Referenz-Binaerdateien — leben auf dem NAS, gehoeren NICHT ins Git
# (Skills lesen sie lokal; Git haelt nur Text + leichte Assets)
*.tiff
*.tif
*.indd
**/produkt-kataloge/

# Behoerden-Dokumenten-Spiegel (Connector behoerden-zh.mjs): die gespiegelten
# amtlichen Formulare/Merkblaetter + Manifest leben auf dem NAS (alle Stationen lesen
# per Symlink denselben Ordner), NICHT im Git. Die Registry (Text) wird versioniert.
**/behoerden-dokumente/

# Claude - Projekt-Config wird versioniert (Backup)
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/settings.json
