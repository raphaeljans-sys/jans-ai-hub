# JANS AI Hub - Microsoft 365 MCP Credentials
# Azure App Registration: SharePoint MCP Connector (JANS)
# Auth: Certificate-based (noetig fuer SharePoint)
#
# Kopiere diese Datei nach .env und trage die echten Werte ein:
#   cp .env.example .env
#
# Zertifikat-Setup (pro Station):
#   1. openssl req -x509 -newkey rsa:2048 -keyout ~/.cli-m365-cert-key.pem -out ~/.cli-m365-cert.pem -days 730 -nodes -subj '/CN=JANS-AI-Hub-M365'
#   2. cat ~/.cli-m365-cert-key.pem ~/.cli-m365-cert.pem > ~/.cli-m365-cert-combined.pem
#   3. chmod 600 ~/.cli-m365-cert-combined.pem ~/.cli-m365-cert-key.pem
#   4. Public-Cert (.cli-m365-cert.pem) in Azure Portal hochladen
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CERTIFICATE_FILE=~/.cli-m365-cert-combined.pem
