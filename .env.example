# JANS AI Hub - Microsoft 365 MCP Credentials
# Azure App Registration: SharePoint MCP Connector (JANS)
# Auth: Certificate-based (noetig fuer SharePoint)
#
# Kopiere diese Datei nach .env und trage die echten Werte ein:
#   cp .env.example .env
#
# Zertifikat-Setup (pro Station):
#   1. openssl req -x509 -newkey rsa:2048 -keyout ~/.cli-m365-cert-key.pem -out ~/.cli-m365-cert.pem -days 730 -nodes -subj '/CN=JANS-AI-Hub-M365'
#   2. cat ~/.cli-m365-cert-key.pem ~/.cli-m365-cert.pem > ~/.cli-m365-cert-combined.pem
#   3. chmod 600 ~/.cli-m365-cert-combined.pem ~/.cli-m365-cert-key.pem
#   4. Public-Cert (.cli-m365-cert.pem) in Azure Portal hochladen
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CERTIFICATE_FILE=~/.cli-m365-cert-combined.pem

# WordPress REST API (raphaeljans.ch)
# Application Password erstellen unter: raphaeljans.ch/wp-admin > Benutzer > Profil > Application Passwords
WP_BASE_URL=https://raphaeljans.ch
WP_USER=
WP_APP_PASSWORD=

# Google Maps (optional) — Geo-Connector Unternehmerfindung
# Ohne Key laeuft der Geo-Connector auf OpenStreetMap (gratis). Mit Key nutzt er
# Google Places (bessere Abdeckung + Rating). Billing-aktivierter Key mit
# "Geocoding API" + "Places API". Anlegen: console.cloud.google.com
# Skill: skills/unternehmerfindung/connectors/geo-maps.mjs
GOOGLE_MAPS_API_KEY=

# bexio (Debitoren/Mahnwesen) — Connector connectors/bexio.mjs
# Liegt aus Sicherheitsgruenden NICHT hier, sondern in ~/.bexio.env (chmod 600).
# Personal Access Token erzeugen: developer.bexio.com > Personal Access Token,
# Scopes mindestens kb_invoice_show + kb_invoice_edit. Dann:
#   echo 'BEXIO_API_TOKEN=DEIN_TOKEN' > ~/.bexio.env && chmod 600 ~/.bexio.env
# BEXIO_API_TOKEN=  (in ~/.bexio.env, nicht hier)
