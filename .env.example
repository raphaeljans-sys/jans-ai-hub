# JANS AI Hub - Microsoft 365 MCP Credentials
# Azure App Registration: JANS AI Hub - Claude MCP
# Kopiere diese Datei nach .env und trage die echten Werte ein:
#   cp .env.example .env
#
# Werte findest du im Azure Portal unter App Registrations
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback
